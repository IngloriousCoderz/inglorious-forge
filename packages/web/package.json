{
  "name": "@inglorious/web",
  "version": "6.3.0",
  "description": "A new web framework that leverages the power of the Inglorious Store combined with the performance and simplicity of lit-html.",
  "author": "Matteo Antony Mistretta <antony.mistretta@gmail.com> (https://ingloriouscoderz.it)",
  "contributors": [
    {
      "name": "Luis Cruz",
      "email": "stackbuilder1228@gmail.com",
      "url": "https://topstar-ai.github.io/"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IngloriousCoderz/inglorious-forge.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/IngloriousCoderz/inglorious-forge/issues"
  },
  "keywords": [
    "lit-html",
    "state",
    "state-management",
    "store",
    "redux",
    "inglorious-store"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js"
    },
    "./compass": {
      "types": "./types/compass.d.ts",
      "import": "./src/compass/index.js"
    },
    "./decorators/with-debounce": {
      "types": "./types/decorators/with-debounce.d.ts",
      "import": "./src/decorators/with-debounce/index.js"
    },
    "./directives/*": {
      "types": "./types/directives/*.d.ts",
      "import": "./src/directives/*.js"
    },
    "./element-size": {
      "types": "./types/element-size.d.ts",
      "import": "./src/element-size/index.js"
    },
    "./form": {
      "types": "./types/form.d.ts",
      "import": "./src/form/index.js"
    },
    "./geolocation": {
      "types": "./types/geolocation.d.ts",
      "import": "./src/geolocation/index.js"
    },
    "./hydrate": "./src/hydrate.js",
    "./router": {
      "types": "./types/router.d.ts",
      "import": "./src/router/index.js"
    },
    "./static": {
      "types": "./types/static.d.ts",
      "import": "./src/static.js"
    },
    "./test": {
      "import": "./src/test.js"
    }
  },
  "files": [
    "src",
    "types",
    "!src/**/*.test.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "test:watch": "vitest",
    "test": "vitest run"
  },
  "dependencies": {
    "@inglorious/utils": "workspace:*",
    "@lit-labs/ssr-client": "^1.1.8",
    "lit-html": "^3.3.1"
  },
  "peerDependencies": {
    "@inglorious/store": "workspace:*"
  },
  "devDependencies": {
    "@inglorious/eslint-config": "workspace:*",
    "prettier": "^3.6.2",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">= 22"
  }
}
