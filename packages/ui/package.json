{
  "name": "@inglorious/ui",
  "version": "0.1.0",
  "description": "A design system for Inglorious Web with render-function components and customizable themes",
  "author": "IceOnFire <antony.mistretta@gmail.com> (https://ingloriouscoderz.it)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IngloriousCoderz/inglorious-forge.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/IngloriousCoderz/inglorious-forge/issues"
  },
  "keywords": [
    "design-system",
    "ui",
    "components",
    "lit-html",
    "inglorious-web",
    "theme"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js"
    },
    "./tokens": "./src/tokens/index.css",
    "./themes/inglorious": "./src/themes/inglorious.css",
    "./themes/material": "./src/themes/material.css",
    "./themes/bootstrap": "./src/themes/bootstrap.css",
    "./button": {
      "types": "./types/button.d.ts",
      "import": "./src/components/button/index.js"
    },
    "./button.css": "./src/controls/button/style.css",
    "./input": {
      "types": "./types/input.d.ts",
      "import": "./src/components/input/index.js"
    },
    "./input.css": "./src/controls/input/style.css",
    "./card": {
      "types": "./types/card.d.ts",
      "import": "./src/components/card/index.js"
    },
    "./card.css": "./src/widgets/card/style.css"
  },
  "files": [
    "src",
    "types",
    "!src/**/*.test.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "test:watch": "vitest",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@inglorious/web": "workspace:*"
  },
  "devDependencies": {
    "@inglorious/eslint-config": "workspace:*",
    "@inglorious/store": "workspace:*",
    "@inglorious/web": "workspace:*",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/web-components-vite": "^10.2.10",
    "happy-dom": "^15.11.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.6.2",
    "storybook": "^10.2.10",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">= 22"
  }
}
